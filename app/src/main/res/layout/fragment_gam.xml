<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".controller.GamFragment">


  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/guesses"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:orientation="vertical"
    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
    app:layout_constraintBottom_toTopOf="@id/current_guess_container"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:stackFromEnd="true"
    tools:listitem="@layout/item_guess"/>

  <LinearLayout
    android:id="@+id/current_guess_container"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    app:layout_constraintBottom_toTopOf="@id/palette_container"
    app:layout_constraintEnd_toStartOf="@id/send"
    app:layout_constraintStart_toStartOf="parent">

    <View
      android:id="@+id/current_color_1"
      android:layout_width="32dp"
      android:layout_height="32dp"
      android:layout_margin="4dp"
      android:background="@drawable/square"/>

    <View
      android:id="@+id/current_color_2"
      android:layout_width="32dp"
      android:layout_height="32dp"
      android:layout_margin="4dp"
      android:background="@drawable/square"/>

    <View
      android:id="@+id/current_color_3"
      android:layout_width="32dp"
      android:layout_height="32dp"
      android:layout_margin="4dp"
      android:background="@drawable/square"/>

    <View
      android:id="@+id/current_color_4"
      android:layout_width="32dp"
      android:layout_height="32dp"
      android:layout_margin="4dp"
      android:background="@drawable/square"/>



  </LinearLayout>

  <ImageButton
    android:id="@+id/send"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:contentDescription="@string/send"
    android:src="@android:drawable/ic_menu_send"
    app:layout_constraintBottom_toTopOf="@id/palette_container"
    app:layout_constraintEnd_toEndOf="parent"/>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/palette_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent">

    <Button
      android:id="@+id/red"
      android:layout_width="64dp"
      android:layout_height="64dp"
      android:layout_margin="4dp"
      android:backgroundTint="#FF0000"
      android:text="@string/red"
      app:layout_constraintBottom_toTopOf="@id/blue"
      app:layout_constraintEnd_toStartOf="@id/orange"
      app:layout_constraintHorizontal_chainStyle="packed"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"/>

    <Button
      android:id="@+id/orange"
      android:layout_width="64dp"
      android:layout_height="64dp"
      android:layout_margin="4dp"
      android:backgroundTint="#FF7F00"
      android:text="@string/orange"
      app:layout_constraintBottom_toTopOf="@id/indigo"
      app:layout_constraintEnd_toStartOf="@id/yellow"
      app:layout_constraintStart_toEndOf="@id/red"
      app:layout_constraintTop_toTopOf="parent"/>

    <Button
      android:id="@+id/yellow"
      android:layout_width="64dp"
      android:layout_height="64dp"
      android:layout_margin="4dp"
      android:backgroundTint="#FFFF00"
      android:text="@string/yellow"
      android:textColor="#000000"
      app:layout_constraintBottom_toTopOf="@id/violet"
      app:layout_constraintEnd_toStartOf="@id/green"
      app:layout_constraintStart_toEndOf="@id/orange"
      app:layout_constraintTop_toTopOf="parent"/>

    <Button
      android:id="@+id/green"
      android:layout_width="64dp"
      android:layout_height="64dp"
      android:layout_margin="4dp"
      android:backgroundTint="#00FF00"
      android:text="@string/green"
      android:textColor="#000000"
      app:layout_constraintBottom_toBottomOf="@id/yellow"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toEndOf="@id/yellow"
      app:layout_constraintTop_toTopOf="parent"/>

    <Button
      android:id="@+id/blue"
      android:layout_width="64dp"
      android:layout_height="64dp"
      android:layout_margin="4dp"
      android:backgroundTint="#0000FF"
      android:text="@string/blue"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toStartOf="@id/indigo"
      app:layout_constraintHorizontal_chainStyle="packed"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/red"/>

    <Button
      android:id="@+id/indigo"
      android:layout_width="64dp"
      android:layout_height="64dp"
      android:layout_margin="4dp"
      android:backgroundTint="#4B0082"
      android:text="@string/indigo"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toStartOf="@id/violet"
      app:layout_constraintStart_toEndOf="@id/blue"
      app:layout_constraintTop_toBottomOf="@id/orange"/>

    <Button
      android:id="@+id/violet"
      android:layout_width="64dp"
      android:layout_height="64dp"
      android:layout_margin="4dp"
      android:backgroundTint="#9400D3"
      android:text="@string/violet"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toEndOf="@id/indigo"
      app:layout_constraintTop_toBottomOf="@id/yellow"/>

  </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
